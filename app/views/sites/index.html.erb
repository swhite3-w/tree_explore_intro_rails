<h1 class="mb-4">Sites</h1>

<div class="list-group mb-4">
  <% @sites.each do |site| %>
    <div class="list-group-item">
      <h2 class="h5 mb-1">
        <%= link_to(site.park.presence || site.street.presence || "View Site", site_path(site), class: "text-decoration-none") %>
      </h2>

      <p class="mb-1">
        <strong>Neighbourhood:</strong>
        <%= link_to site.neighbourhood.name, neighbourhood_path(site.neighbourhood) %>
      </p>

      <% if site.location_class.present? %>
        <p class="mb-1"><strong>Location Class:</strong> <%= site.location_class %></p>
      <% end %>

      <% if site.property_type.present? %>
        <p class="mb-0"><strong>Property Type:</strong> <%= site.property_type %></p>
      <% end %>
    </div>
  <% end %>
</div>

<div class="mt-3">
  <%= paginate @sites %>
  <p class="mb-3"><strong>Results:</strong> <%= @sites.total_count %></p>
</div>