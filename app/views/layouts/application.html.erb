<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Winnipeg Tree Explorer</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  </head>

  <body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-success mb-4">
      <div class="container">
        <span class="navbar-brand mb-0 h1">Winnipeg Tree Explorer</span>

        <div class="navbar-nav">
          <%= link_to "Trees", trees_path, class: "nav-link text-white" %>
          <%= link_to "Sites", sites_path, class: "nav-link text-white" %>
          <%= link_to "Neighbourhoods", neighbourhoods_path, class: "nav-link text-white" %>
          <%= link_to "About", about_path, class: "nav-link text-white" %>
        </div>
      </div>
    </nav>

    <main class="container pb-4">
      <%= yield %>
    </main>
  </body>
</html>