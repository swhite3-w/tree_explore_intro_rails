<h1 class="mb-4">Neighbourhoods</h1>

<div class="list-group mb-4">
  <% @neighbourhoods.each do |neighbourhood| %>
    <div class="list-group-item">
      <h2 class="h5 mb-1">
        <%= link_to neighbourhood.name, neighbourhood_path(neighbourhood), class: "text-decoration-none" %>
      </h2>

      <p class="mb-1"><strong>Electoral Ward:</strong> <%= neighbourhood.electoral_ward %></p>
      <p class="mb-0"><strong>Sites:</strong> <%= neighbourhood.sites.count %></p>
    </div>
  <% end %>
</div>

<div class="mt-3">
  <%= paginate @neighbourhoods %>
  <p class="mb-3"><strong>Results:</strong> <%= @neighbourhoods.total_count %></p>
</div>